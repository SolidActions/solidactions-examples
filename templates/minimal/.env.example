# Shared secret for HMAC verification on incoming webhook calls.
# The platform gateway uses this to verify X-Hub-Signature-256 / X-Signature-256
# / Stripe-Signature headers. Any value the caller also knows is fine for testing.
WEBHOOK_SECRET=replace-me-with-a-random-string

# Example of a workflow-consumed env var — referenced via process.env.GREETING.
GREETING=Hello
